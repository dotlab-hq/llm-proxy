{
  "name": "@dotlab-hq/llm-proxy",
  "version": "1.0.4",
  "description": "LLM Proxy server with OpenAI compatibility",
  "type": "module",
  "bin": {
    "llm-proxy": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "url": "https://github.com/dotlab-hq/llm-proxy"
  },
  "scripts": {
    "start": "bun run dist/server.js",
    "dev": "bun run --hot src/server.ts",
    "cli": "bun run dist/cli.js",
    "build": "bun build src/cli/index.ts --outfile dist/cli.js --target bun && bun build src/server.ts --outfile dist/server.js --target bun",
    "link": "bun link",
    "generate:schema": "bun scripts/schema-generate.ts",
    "generate:schema:path:local": "bun scripts/schema-local-path.ts",
    "typecheck": "bun tsc --noEmit",
    "testify": "bun test tests/prod.test.ts"
  },
  "keywords": [
    "llm",
    "proxy",
    "openai",
    "api"
  ],
  "author": "Wpsadi",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@hono/zod-openapi": "^1.3.0",
    "chalk": "^5.6.2",
    "hono": "^4.12.16",
    "zod": "^4.4.1"
  }
}