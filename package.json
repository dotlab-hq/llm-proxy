{
  "name": "@dotlabs-hq/llm-proxy",
  "version": "1.0.0",
  "description": "LLM Proxy server with OpenAI compatibility",
  "module": "src/index.ts",
  "type": "module",
  "bin": {
    "llm-proxy": "./dist/cli.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts"
  },
  "scripts": {
    "start": "bun run src/server.ts",
    "dev": "bun run --hot src/server.ts",
    "cli": "bun run src/cli/index.ts",
    "build": "bun build src/cli/index.ts --outfile dist/cli.js --target bun",
    "generate:schema": "bun scripts/schema-generate.ts",
    "generate:schema:path:local": "bun scripts/schema-local-path.ts",
    "types": "bun tsc --noEmit",
    "testify": "bun test tests/prod.test.ts"
  },
  "keywords": [
    "llm",
    "proxy",
    "openai",
    "api"
  ],
  "author": "Dotlabs HQ",
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.3.0",
    "@langchain/openai": "^1.4.5",
    "clack": "^0.1.0",
    "hono": "^4.12.16",
    "zod": "^4.4.1"
  }
}